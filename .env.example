# Database - PostgreSQL Connection
DATABASE_URL="postgresql://username:password@host:5432/dbname"

# Next.js Configuration
NEXTAUTH_URL="https://yourdomain.com"
NEXTAUTH_SECRET="generate-a-random-secret-key-for-production"

# Site Configuration (used throughout the website)
SITE_NAME="Flyover Car Rental"
SITE_DESCRIPTION="Premium and reliable car rental service in Pokhara."
SITE_URL="https://yourdomain.com"
CONTACT_EMAIL="your-email@example.com"
CONTACT_PHONE="your-phone-number"
CONTACT_ADDRESS="Your physical address"

# Optional: Image Upload to Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Supabase (recommended for free Postgres + Storage)
# Create a Supabase project and set these values
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_SUPABASE_BUCKET="uploads"

# Optional: Email Service for Contact Forms
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
